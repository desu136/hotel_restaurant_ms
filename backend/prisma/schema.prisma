generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String               @id @default(uuid()) @db.Uuid
  business_name     String
  owner_name        String
  phone             String
  email             String
  business_type     BusinessType
  status            TenantStatus         @default(PENDING)
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt
  deleted_at        DateTime?
  address           String?
  license_info      String?
  tax_info          String?
  activity_logs     ActivityLog[]
  audit_logs        AuditLog[]
  branches          Branch[]
  categories        Category[]
  dexel_sync_logs   DexelSyncLog[]
  menu_items        MenuItem[]
  orders            Order[]
  reservations      Reservation[]
  restaurant_tables RestaurantTable[]
  restaurants       Restaurant[]
  room_types        RoomType[]
  rooms             Room[]
  modules           TenantModule[]
  subscriptions     TenantSubscription[]
  users             User[]
  masterCategories  MasterCategory[]
  masterMenuItems   MasterMenuItem[]

  @@map("tenants")
}

model PlatformSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("platform_settings")
}

model Module {
  id             String         @id @default(uuid()) @db.Uuid
  code           String         @unique
  name           String
  description    String?
  is_active      Boolean        @default(true)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  plan_modules   PlanModule[]
  tenant_modules TenantModule[]

  @@map("modules")
}

model SubscriptionPlan {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  monthly_price Decimal              @db.Decimal(10, 2)
  annual_price  Decimal              @db.Decimal(10, 2)
  trial_days    Int                  @default(14)
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt
  deleted_at    DateTime?
  description   String?
  modules       PlanModule[]
  subscriptions TenantSubscription[]

  @@map("subscription_plans")
}

model PlanModule {
  plan_id   String           @db.Uuid
  module_id String           @db.Uuid
  module    Module           @relation(fields: [module_id], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@id([plan_id, module_id])
  @@map("plan_modules")
}

model TenantSubscription {
  id         String             @id @default(uuid()) @db.Uuid
  tenant_id  String             @db.Uuid
  plan_id    String             @db.Uuid
  start_date DateTime
  end_date   DateTime
  status     SubscriptionStatus @default(TRIAL)
  created_at DateTime           @default(now())
  updated_at DateTime           @updatedAt
  deleted_at DateTime?
  plan       SubscriptionPlan   @relation(fields: [plan_id], references: [id])
  tenant     Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("tenant_subscriptions")
}

model TenantModule {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  enabled    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  module_id  String   @db.Uuid
  module     Module   @relation(fields: [module_id], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, module_id])
  @@map("tenant_modules")
}

model Branch {
  id            String @id @default(uuid()) @db.Uuid
  tenant_id     String @db.Uuid
  restaurant_id String @db.Uuid

  name    String
  address String?
  phone   String?
  logo_url String?
  banner_url String?

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  orders           Order[]
  reservations     Reservation[]
  rooms            Room[]
  users            User[]
  categories       Category[]
  menuItems        MenuItem[]
  restaurantTables RestaurantTable[]

  @@index([tenant_id])
  @@index([restaurant_id])
  @@map("branches")
}

model User {
  id            String            @id @default(uuid()) @db.Uuid
  tenant_id     String?           @db.Uuid
  branch_id     String?           @db.Uuid
  full_name     String
  email         String            @unique
  phone         String?
  password_hash String
  status        UserStatus        @default(ACTIVE)
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  deleted_at    DateTime?
  avatar_url    String?
  audit_logs    AuditLog[]
  roles         UserRole[]
  waiter_tables RestaurantTable[] @relation("WaiterTables")
  branch        Branch?           @relation(fields: [branch_id], references: [id])
  tenant        Tenant?           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([branch_id])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id         String           @id @default(uuid()) @db.Uuid
  code       String           @unique
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt
  roles      RolePermission[]

  @@map("permissions")
}

model UserRole {
  user_id String @db.Uuid
  role_id String @db.Uuid
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@map("user_roles")
}

model RolePermission {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  user_id   String   @db.Uuid
  tenant_id String   @db.Uuid
  action    String
  resource  String
  timestamp DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@index([user_id])
  @@map("audit_logs")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenant_id String   @db.Uuid
  action    String
  details   Json?
  timestamp DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id])
  @@map("activity_logs")
}

model RoomType {
  id         String    @id @default(uuid()) @db.Uuid
  tenant_id  String    @db.Uuid
  name       String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?
  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  rooms      Room[]

  @@map("room_types")
}

model Room {
  id              String     @id @default(uuid()) @db.Uuid
  tenant_id       String     @db.Uuid
  branch_id       String     @db.Uuid
  room_type_id    String     @db.Uuid
  room_number     String
  price_per_night Decimal    @db.Decimal(10, 2)
  status          RoomStatus @default(AVAILABLE)
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt
  deleted_at      DateTime?
  orders          Order[]
  branch          Branch     @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  room_type       RoomType   @relation(fields: [room_type_id], references: [id])
  tenant          Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("rooms")
}

model Customer {
  id           String             @id @default(uuid()) @db.Uuid
  full_name    String
  phone        String?
  email        String?
  source       CustomerSource     @default(WEB)
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  identities   CustomerIdentity[]
  feedback     Feedback[]
  orders       Order[]
  reservations Reservation[]

  @@map("customers")
}

model CustomerIdentity {
  id               String   @id @default(uuid()) @db.Uuid
  customer_id      String   @db.Uuid
  external_user_id String
  provider         String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  customer         Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@unique([external_user_id, provider])
  @@map("customer_identities")
}

model Reservation {
  id               String            @id @default(uuid()) @db.Uuid
  tenant_id        String            @db.Uuid
  branch_id        String            @db.Uuid
  customer_id      String            @db.Uuid
  reservation_type ReservationType
  status           ReservationStatus @default(PENDING)
  reservation_date DateTime
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  branch           Branch            @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  customer         Customer          @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model Restaurant {
  id        String  @id @default(uuid()) @db.Uuid
  tenant_id String  @db.Uuid
  parent_id String? @db.Uuid

  name       String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  banner_url String?
  logo_url   String?

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  parent   Restaurant?  @relation("RestaurantChain", fields: [parent_id], references: [id])
  children Restaurant[] @relation("RestaurantChain")

  branches Branch[] // <-- One restaurant has many branches
  
  masterCategories MasterCategory[]
  masterMenuItems  MasterMenuItem[]

  @@map("restaurants")
}

model MasterCategory {
  id            String @id @default(uuid()) @db.Uuid
  tenant_id     String @db.Uuid
  restaurant_id String @db.Uuid

  name String

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  parent_id String? @db.Uuid

  parent MasterCategory? @relation("MasterCategoryTree", fields: [parent_id], references: [id], onDelete: Cascade)

  subcategories MasterCategory[] @relation("MasterCategoryTree")

  restaurant Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  menu_items MasterMenuItem[]
  categories Category[]
}

model Category {
  id String @id @default(uuid()) @db.Uuid

  tenant_id String @db.Uuid
  branch_id String @db.Uuid

  master_category_id String? @db.Uuid

  name String

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  parent_id String? @db.Uuid

  parent Category? @relation("CategoryTree", fields: [parent_id], references: [id], onDelete: Cascade)

  subcategories Category[] @relation("CategoryTree")

  branch Branch @relation(fields: [branch_id], references: [id], onDelete: Cascade)

  master_category MasterCategory? @relation(fields: [master_category_id], references: [id])

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  menu_items   MenuItem[]
}

model MasterMenuItem {
  id                 String   @id @default(uuid()) @db.Uuid
  tenant_id          String   @db.Uuid
  restaurant_id      String   @db.Uuid

  master_category_id String?  @db.Uuid

  dexel_product_id   String   @default("")

  display_name       String
  description        String?
  image_url          String?
  image_urls         Json?
  customizations     Json?

  price              Decimal  @default(0) @db.Decimal(10, 2)
  availability       Boolean  @default(true)
  prep_time          Int      @default(0)

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  deleted_at         DateTime?

  restaurant         Restaurant      @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)
  category           MasterCategory? @relation(fields: [master_category_id], references: [id])
  tenant             Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  menuItems          MenuItem[]
}

model MenuItem {
  id String @id @default(uuid()) @db.Uuid

  tenant_id String @db.Uuid

  branch_id String @db.Uuid

  dexel_product_id String @default("")

  master_menu_item_id String? @db.Uuid

  category_id String? @db.Uuid

  display_name String

  description String?

  image_url String?

  image_urls Json?

  customizations Json?

  availability Boolean @default(true)
  prep_time    Int     @default(0)

  price Decimal @db.Decimal(10, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  branch           Branch          @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  category         Category?       @relation(fields: [category_id], references: [id])
  master_menu_item MasterMenuItem? @relation(fields: [master_menu_item_id], references: [id])
  tenant           Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  order_items  OrderItem[]
}

model RestaurantTable {
  id           String      @id @default(uuid()) @db.Uuid
  tenant_id    String      @db.Uuid
  branch_id    String      @db.Uuid
  table_number String
  capacity     Int
  waiter_id    String?     @db.Uuid
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt
  orders       Order[]
  qr_codes     QRCode[]
  branch       Branch      @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  tenant       Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  waiter       User?       @relation("WaiterTables", fields: [waiter_id], references: [id])

  @@index([waiter_id])
  @@map("restaurant_tables")
}

model QRCode {
  id         String          @id @default(uuid()) @db.Uuid
  table_id   String          @db.Uuid
  token      String          @unique
  status     String
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  table      RestaurantTable @relation(fields: [table_id], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

model Order {
  id              String           @id @default(uuid()) @db.Uuid
  tenant_id       String           @db.Uuid
  branch_id       String           @db.Uuid
  customer_id     String           @db.Uuid
  table_id        String?          @db.Uuid
  room_id         String?          @db.Uuid
  waiter_id       String?          @db.Uuid
  order_number    String?
  order_type      OrderType
  status          OrderStatus      @default(PENDING)
  total_amount    Decimal          @db.Decimal(10, 2)
  estimated_prep_time Int          @default(0)
  estimated_ready_at  DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  bills           Bill[]
  deliveries      Delivery[]
  feedbacks       Feedback[]
  kitchen_tickets KitchenTicket[]
  items           OrderItem[]
  branch          Branch           @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  room            Room?            @relation(fields: [room_id], references: [id])
  table           RestaurantTable? @relation(fields: [table_id], references: [id])
  tenant          Tenant           @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("orders")
}

model OrderItem {
  id             String   @id @default(uuid()) @db.Uuid
  order_id       String   @db.Uuid
  menu_item_id   String   @db.Uuid
  quantity       Int
  unit_price     Decimal  @db.Decimal(10, 2)
  customizations Json?
  menu_item      MenuItem @relation(fields: [menu_item_id], references: [id])
  order          Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model KitchenTicket {
  id         String              @id @default(uuid()) @db.Uuid
  order_id   String              @db.Uuid
  chef_id    String?             @db.Uuid
  status     KitchenTicketStatus @default(PENDING)
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt
  order      Order               @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("kitchen_tickets")
}

model Bill {
  id             String             @id @default(uuid()) @db.Uuid
  order_id       String             @db.Uuid
  amount         Decimal            @db.Decimal(10, 2)
  payment_status PaymentStatus      @default(PENDING)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  order          Order              @relation(fields: [order_id], references: [id], onDelete: Cascade)
  transactions   DexelTransaction[]

  @@map("bills")
}

model DexelTransaction {
  id                   String     @id @default(uuid()) @db.Uuid
  bill_id              String     @db.Uuid
  dexel_transaction_id String
  sync_status          SyncStatus @default(PENDING)
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt
  bill                 Bill       @relation(fields: [bill_id], references: [id], onDelete: Cascade)

  @@map("dexel_transactions")
}

model Delivery {
  id               String         @id @default(uuid()) @db.Uuid
  order_id         String         @db.Uuid
  driver_id        String?        @db.Uuid
  delivery_address String
  status           DeliveryStatus @default(ASSIGNED)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  order            Order          @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("deliveries")
}

model Feedback {
  id          String   @id @default(uuid()) @db.Uuid
  customer_id String   @db.Uuid
  order_id    String   @db.Uuid
  rating      Int
  comment     String?
  created_at  DateTime @default(now())
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

model DexelSyncLog {
  id               String     @id @default(uuid()) @db.Uuid
  tenant_id        String     @db.Uuid
  operation        String
  request_payload  Json?
  response_payload Json?
  status           SyncStatus @default(PENDING)
  created_at       DateTime   @default(now())
  tenant           Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@map("dexel_sync_logs")
}

enum BusinessType {
  HOTEL
  RESTAURANT
  HOTEL_RESTAURANT
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RoomStatus {
  AVAILABLE
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum CustomerSource {
  WEB
  MINI_APP
}

enum ReservationType {
  ROOM
  TABLE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderType {
  DINE_IN
  ROOM_SERVICE
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
  OUT_FOR_DELIVERY
  DELIVERED
}

enum KitchenTicketStatus {
  PENDING
  PREPARING
  READY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  DELIVERED
  CANCELLED
}
